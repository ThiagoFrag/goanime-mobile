# GoAnime Mobile - environment variables
# Copy to .env and fill values. .env is gitignored.

# TMDB API key (https://www.themoviedb.org/settings/api)
# WARNING: bundled in APK assets; rotate if compromised.
TMDB_API_KEY=your_tmdb_api_key_here

# Backend de sincronização de favoritos (deixe vazio para desabilitar)
# Exemplo: https://sync.exemplo.com
SYNC_BASE_URL=

# Backend do GoMang scraper (manga). Deixe vazio para usar scraper Dart embarcado.
# Exemplo: https://gomang.exemplo.com
GOMANG_BASE_URL=
